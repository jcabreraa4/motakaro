{
  "name": "motakaro",
  "version": "0.0.1",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "convex": "^1.35.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "build:clients": "turbo run build --filter=clients --concurrency=1 && cp -r apps/clients/.next/static apps/clients/.next/standalone/apps/clients/.next/static && cp -r apps/clients/public apps/clients/.next/standalone/apps/clients/public",
    "start:clients": "PORT=3000 HOSTNAME=0.0.0.0 node apps/clients/.next/standalone/apps/clients/server.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
