{
  "name": "motakaro",
  "version": "0.0.1",
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "convex": "^1.35.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:admins": "turbo run build --filter=admins --concurrency=1",
    "build:clients": "turbo run build --filter=clients --concurrency=1",
    "build:landing": "turbo run build --filter=landing --concurrency=1",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
